generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DocumentStatus {
  DRAFT
  POSTED
  CANCELLED
  STORNO
  PARTIALLY_RETURNED
  FULLY_RETURNED

  @@map("document_status")
}

enum MovementType {
  PURCHASE_IN
  SALE_OUT
  SALES_RETURN_IN
  ADJUSTMENT_PLUS
  ADJUSTMENT_MINUS
  TRANSFER_OUT
  TRANSFER_IN
  COUNT_IN
  COUNT_OUT

  @@map("movement_type")
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID

  @@map("payment_status")
}

enum FiscalStatus {
  DRAFT
  PENDING
  SUBMITTED
  ACCEPTED
  REJECTED
  FAILED

  @@map("fiscal_status")
}

enum FiscalMode {
  DISABLED
  SANDBOX
  LIVE

  @@map("fiscal_mode")
}

enum FinanceSettlementType {
  RECEIPT
  PAYMENT

  @@map("finance_settlement_type")
}

enum FinanceSettlementStatus {
  OPEN
  PARTIALLY_ALLOCATED
  FULLY_ALLOCATED

  @@map("finance_settlement_status")
}

enum FinancialPeriodStatus {
  OPEN
  SOFT_CLOSED
  CLOSED

  @@map("financial_period_status")
}

enum FinanceAccountType {
  CASH
  BANK

  @@map("finance_account_type")
}

enum FinanceAccountTransactionType {
  OPENING
  MANUAL_IN
  MANUAL_OUT
  TRANSFER_IN
  TRANSFER_OUT
  RECEIPT
  PAYMENT

  @@map("finance_account_transaction_type")
}

enum FinanceStatementLineDirection {
  IN
  OUT

  @@map("finance_statement_line_direction")
}

enum FinanceStatementLineStatus {
  UNMATCHED
  PARTIALLY_MATCHED
  MATCHED

  @@map("finance_statement_line_status")
}

model Role {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(30)
  name      String   @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  users     User[]
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("roles")
}

model User {
  id                                  String                        @id @default(uuid()) @db.Uuid
  roleId                              String                        @map("role_id") @db.Uuid
  fullName                            String                        @map("full_name") @db.VarChar(150)
  email                               String                        @unique @db.VarChar(150)
  passwordHash                        String                        @map("password_hash") @db.VarChar(255)
  isActive                            Boolean                       @default(true) @map("is_active")
  role                                Role                          @relation(fields: [roleId], references: [id])
  createdPurchases                    PurchaseInvoice[]             @relation("PurchaseCreatedBy")
  postedPurchases                     PurchaseInvoice[]             @relation("PurchasePostedBy")
  createdSales                        SalesInvoice[]                @relation("SalesCreatedBy")
  postedSales                         SalesInvoice[]                @relation("SalesPostedBy")
  createdReturns                      SalesReturn[]                 @relation("ReturnCreatedBy")
  postedReturns                       SalesReturn[]                 @relation("ReturnPostedBy")
  createdFinanceSettlements           FinanceSettlement[]           @relation("FinanceSettlementCreatedBy")
  createdFinanceSettlementAllocations FinanceSettlementAllocation[] @relation("FinanceSettlementAllocationCreatedBy")
  createdFinanceAccountTransactions   FinanceAccountTransaction[]   @relation("FinanceAccountTransactionCreatedBy")
  createdFinanceStatementLines        FinanceStatementLine[]        @relation("FinanceStatementLineCreatedBy")
  createdFinanceStatementMatches      FinanceStatementMatch[]       @relation("FinanceStatementMatchCreatedBy")
  closedFinancialPeriods              FinancialPeriod[]             @relation("FinancialPeriodClosedBy")
  reopenedFinancialPeriods            FinancialPeriod[]             @relation("FinancialPeriodReopenedBy")
  auditLogs                           AuditLog[]
  createdAt                           DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                           DateTime                      @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([roleId])
  @@map("users")
}

model ItemCategory {
  id        String         @id @default(uuid()) @db.Uuid
  code      String         @unique @db.VarChar(30)
  name      String         @db.VarChar(100)
  parentId  String?        @map("parent_id") @db.Uuid
  parent    ItemCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  ItemCategory[] @relation("CategoryTree")
  items     Item[]
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([parentId])
  @@map("item_categories")
}

model Unit {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(20)
  name      String   @db.VarChar(50)
  items     Item[]
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("units")
}

model TaxRate {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(20)
  name        String   @db.VarChar(50)
  ratePercent Decimal  @map("rate_percent") @db.Decimal(5, 2)
  isActive    Boolean  @default(true) @map("is_active")
  items       Item[]
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("tax_rates")
}

model Warehouse {
  id               String            @id @default(uuid()) @db.Uuid
  code             String            @unique @db.VarChar(20)
  name             String            @db.VarChar(100)
  address          String?           @db.VarChar(255)
  isActive         Boolean           @default(true) @map("is_active")
  purchaseInvoices PurchaseInvoice[]
  salesInvoices    SalesInvoice[]
  stockMovements   StockMovement[]
  stockBalances    StockBalance[]
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("warehouses")
}

model Item {
  id                    String                @id @default(uuid()) @db.Uuid
  code                  String                @unique @db.VarChar(50)
  barcode               String?               @unique @db.VarChar(100)
  name                  String                @db.VarChar(200)
  description           String?
  categoryId            String                @map("category_id") @db.Uuid
  unitId                String                @map("unit_id") @db.Uuid
  taxRateId             String                @map("tax_rate_id") @db.Uuid
  standardPurchasePrice Decimal               @map("standard_purchase_price") @db.Decimal(18, 2)
  standardSalesPrice    Decimal               @map("standard_sales_price") @db.Decimal(18, 2)
  minSalesPrice         Decimal?              @map("min_sales_price") @db.Decimal(18, 2)
  isActive              Boolean               @default(true) @map("is_active")
  category              ItemCategory          @relation(fields: [categoryId], references: [id])
  unit                  Unit                  @relation(fields: [unitId], references: [id])
  taxRate               TaxRate               @relation(fields: [taxRateId], references: [id])
  purchaseLines         PurchaseInvoiceLine[]
  salesLines            SalesInvoiceLine[]
  returnLines           SalesReturnLine[]
  stockMovements        StockMovement[]
  stockBalances         StockBalance[]
  createdAt             DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([categoryId])
  @@index([unitId])
  @@index([taxRateId])
  @@map("items")
}

model Supplier {
  id                 String              @id @default(uuid()) @db.Uuid
  code               String              @unique @db.VarChar(30)
  name               String              @db.VarChar(200)
  fiscalNo           String?             @map("fiscal_no") @db.VarChar(50)
  vatNo              String?             @map("vat_no") @db.VarChar(50)
  address            String?             @db.VarChar(255)
  city               String?             @db.VarChar(100)
  phone              String?             @db.VarChar(50)
  email              String?             @db.VarChar(150)
  paymentTermsDays   Int?                @map("payment_terms_days")
  isActive           Boolean             @default(true) @map("is_active")
  notes              String?
  purchaseInvoices   PurchaseInvoice[]
  financeSettlements FinanceSettlement[] @relation("SupplierFinanceSettlements")
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("suppliers")
}

model Customer {
  id                     String              @id @default(uuid()) @db.Uuid
  code                   String              @unique @db.VarChar(30)
  name                   String              @db.VarChar(200)
  fiscalNo               String?             @map("fiscal_no") @db.VarChar(50)
  vatNo                  String?             @map("vat_no") @db.VarChar(50)
  address                String?             @db.VarChar(255)
  city                   String?             @db.VarChar(100)
  phone                  String?             @db.VarChar(50)
  email                  String?             @db.VarChar(150)
  creditLimit            Decimal?            @map("credit_limit") @db.Decimal(18, 2)
  defaultDiscountPercent Decimal?            @map("default_discount_percent") @db.Decimal(5, 2)
  isActive               Boolean             @default(true) @map("is_active")
  notes                  String?
  salesInvoices          SalesInvoice[]
  salesReturns           SalesReturn[]
  financeSettlements     FinanceSettlement[] @relation("CustomerFinanceSettlements")
  createdAt              DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("customers")
}

model PaymentMethod {
  id            String         @id @default(uuid()) @db.Uuid
  code          String         @unique @db.VarChar(20)
  name          String         @db.VarChar(50)
  isActive      Boolean        @default(true) @map("is_active")
  salesInvoices SalesInvoice[]
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("payment_methods")
}

model FinanceAccount {
  id             String                      @id @default(uuid()) @db.Uuid
  code           String                      @unique @db.VarChar(30)
  name           String                      @db.VarChar(120)
  accountType    FinanceAccountType          @map("account_type")
  currencyCode   String                      @default("EUR") @map("currency_code") @db.VarChar(10)
  bankName       String?                     @map("bank_name") @db.VarChar(120)
  bankAccountNo  String?                     @map("bank_account_no") @db.VarChar(80)
  iban           String?                     @db.VarChar(80)
  swiftCode      String?                     @map("swift_code") @db.VarChar(30)
  openingBalance Decimal                     @default(0) @map("opening_balance") @db.Decimal(18, 2)
  currentBalance Decimal                     @default(0) @map("current_balance") @db.Decimal(18, 2)
  isActive       Boolean                     @default(true) @map("is_active")
  notes          String?
  transactions   FinanceAccountTransaction[]
  statementLines FinanceStatementLine[]
  createdAt      DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([accountType, isActive])
  @@map("finance_accounts")
}

model DocumentSeries {
  id           String            @id @default(uuid()) @db.Uuid
  code         String            @unique @db.VarChar(30)
  documentType String            @map("document_type") @db.VarChar(30)
  prefix       String            @db.VarChar(20)
  nextNumber   Int               @default(1) @map("next_number")
  isActive     Boolean           @default(true) @map("is_active")
  purchases    PurchaseInvoice[]
  sales        SalesInvoice[]
  returns      SalesReturn[]
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([documentType])
  @@map("document_series")
}

model PurchaseInvoice {
  id                           String                        @id @default(uuid()) @db.Uuid
  seriesId                     String                        @map("series_id") @db.Uuid
  supplierId                   String                        @map("supplier_id") @db.Uuid
  warehouseId                  String                        @map("warehouse_id") @db.Uuid
  docNo                        String                        @unique @map("doc_no") @db.VarChar(50)
  supplierInvoiceNo            String?                       @map("supplier_invoice_no") @db.VarChar(100)
  docDate                      DateTime                      @map("doc_date") @db.Date
  dueDate                      DateTime?                     @map("due_date") @db.Date
  status                       DocumentStatus                @default(DRAFT)
  paymentStatus                PaymentStatus                 @default(UNPAID) @map("payment_status")
  subtotal                     Decimal                       @db.Decimal(18, 2)
  discountTotal                Decimal                       @map("discount_total") @db.Decimal(18, 2)
  taxTotal                     Decimal                       @map("tax_total") @db.Decimal(18, 2)
  grandTotal                   Decimal                       @map("grand_total") @db.Decimal(18, 2)
  amountPaid                   Decimal                       @default(0) @map("amount_paid") @db.Decimal(18, 2)
  notes                        String?
  createdById                  String                        @map("created_by") @db.Uuid
  postedById                   String?                       @map("posted_by") @db.Uuid
  supplier                     Supplier                      @relation(fields: [supplierId], references: [id])
  warehouse                    Warehouse                     @relation(fields: [warehouseId], references: [id])
  series                       DocumentSeries                @relation(fields: [seriesId], references: [id])
  createdBy                    User                          @relation("PurchaseCreatedBy", fields: [createdById], references: [id])
  postedBy                     User?                         @relation("PurchasePostedBy", fields: [postedById], references: [id])
  lines                        PurchaseInvoiceLine[]
  stockMovements               StockMovement[]
  sourceFinanceSettlements     FinanceSettlement[]           @relation("FinanceSettlementSourcePurchaseInvoice")
  financeSettlementAllocations FinanceSettlementAllocation[] @relation("FinanceSettlementTargetPurchaseInvoice")
  createdAt                    DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  postedAt                     DateTime?                     @map("posted_at") @db.Timestamptz(6)
  updatedAt                    DateTime                      @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([seriesId])
  @@index([supplierId])
  @@index([warehouseId])
  @@index([createdById])
  @@index([postedById])
  @@index([docDate])
  @@map("purchase_invoices")
}

model PurchaseInvoiceLine {
  id                String          @id @default(uuid()) @db.Uuid
  purchaseInvoiceId String          @map("purchase_invoice_id") @db.Uuid
  itemId            String          @map("item_id") @db.Uuid
  lineNo            Int             @map("line_no")
  description       String?         @db.VarChar(255)
  qty               Decimal         @db.Decimal(18, 3)
  unitPrice         Decimal         @map("unit_price") @db.Decimal(18, 2)
  discountPercent   Decimal         @map("discount_percent") @db.Decimal(5, 2)
  discountAmount    Decimal         @map("discount_amount") @db.Decimal(18, 2)
  taxPercent        Decimal         @map("tax_percent") @db.Decimal(5, 2)
  netAmount         Decimal         @map("net_amount") @db.Decimal(18, 2)
  taxAmount         Decimal         @map("tax_amount") @db.Decimal(18, 2)
  grossAmount       Decimal         @map("gross_amount") @db.Decimal(18, 2)
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  purchaseInvoice   PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
  item              Item            @relation(fields: [itemId], references: [id])

  @@unique([purchaseInvoiceId, lineNo])
  @@index([itemId])
  @@map("purchase_invoice_lines")
}

model SalesInvoice {
  id                           String                        @id @default(uuid()) @db.Uuid
  seriesId                     String                        @map("series_id") @db.Uuid
  customerId                   String                        @map("customer_id") @db.Uuid
  warehouseId                  String                        @map("warehouse_id") @db.Uuid
  paymentMethodId              String?                       @map("payment_method_id") @db.Uuid
  docNo                        String                        @unique @map("doc_no") @db.VarChar(50)
  docDate                      DateTime                      @map("doc_date") @db.Date
  dueDate                      DateTime?                     @map("due_date") @db.Date
  status                       DocumentStatus                @default(DRAFT)
  paymentStatus                PaymentStatus                 @default(UNPAID) @map("payment_status")
  subtotal                     Decimal                       @db.Decimal(18, 2)
  discountTotal                Decimal                       @map("discount_total") @db.Decimal(18, 2)
  taxTotal                     Decimal                       @map("tax_total") @db.Decimal(18, 2)
  grandTotal                   Decimal                       @map("grand_total") @db.Decimal(18, 2)
  amountPaid                   Decimal                       @default(0) @map("amount_paid") @db.Decimal(18, 2)
  fiscalStatus                 FiscalStatus                  @default(DRAFT) @map("fiscal_status")
  fiscalReference              String?                       @map("fiscal_reference") @db.VarChar(150)
  fiscalizedAt                 DateTime?                     @map("fiscalized_at") @db.Timestamptz(6)
  fiscalError                  String?                       @map("fiscal_error") @db.VarChar(255)
  notes                        String?
  createdById                  String                        @map("created_by") @db.Uuid
  postedById                   String?                       @map("posted_by") @db.Uuid
  series                       DocumentSeries                @relation(fields: [seriesId], references: [id])
  customer                     Customer                      @relation(fields: [customerId], references: [id])
  warehouse                    Warehouse                     @relation(fields: [warehouseId], references: [id])
  paymentMethod                PaymentMethod?                @relation(fields: [paymentMethodId], references: [id])
  createdBy                    User                          @relation("SalesCreatedBy", fields: [createdById], references: [id])
  postedBy                     User?                         @relation("SalesPostedBy", fields: [postedById], references: [id])
  lines                        SalesInvoiceLine[]
  returns                      SalesReturn[]
  stockMovements               StockMovement[]
  sourceFinanceSettlements     FinanceSettlement[]           @relation("FinanceSettlementSourceSalesInvoice")
  financeSettlementAllocations FinanceSettlementAllocation[] @relation("FinanceSettlementTargetSalesInvoice")
  createdAt                    DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  postedAt                     DateTime?                     @map("posted_at") @db.Timestamptz(6)
  updatedAt                    DateTime                      @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([seriesId])
  @@index([customerId])
  @@index([warehouseId])
  @@index([paymentMethodId])
  @@index([createdById])
  @@index([postedById])
  @@index([docDate])
  @@map("sales_invoices")
}

model SalesInvoiceLine {
  id              String            @id @default(uuid()) @db.Uuid
  salesInvoiceId  String            @map("sales_invoice_id") @db.Uuid
  itemId          String            @map("item_id") @db.Uuid
  lineNo          Int               @map("line_no")
  description     String?           @db.VarChar(255)
  qty             Decimal           @db.Decimal(18, 3)
  unitPrice       Decimal           @map("unit_price") @db.Decimal(18, 2)
  discountPercent Decimal           @map("discount_percent") @db.Decimal(5, 2)
  discountAmount  Decimal           @map("discount_amount") @db.Decimal(18, 2)
  taxPercent      Decimal           @map("tax_percent") @db.Decimal(5, 2)
  netAmount       Decimal           @map("net_amount") @db.Decimal(18, 2)
  taxAmount       Decimal           @map("tax_amount") @db.Decimal(18, 2)
  grossAmount     Decimal           @map("gross_amount") @db.Decimal(18, 2)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  salesInvoice    SalesInvoice      @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)
  item            Item              @relation(fields: [itemId], references: [id])
  returnLines     SalesReturnLine[]

  @@unique([salesInvoiceId, lineNo])
  @@index([itemId])
  @@map("sales_invoice_lines")
}

model SalesReturn {
  id              String            @id @default(uuid()) @db.Uuid
  seriesId        String            @map("series_id") @db.Uuid
  salesInvoiceId  String            @map("sales_invoice_id") @db.Uuid
  customerId      String            @map("customer_id") @db.Uuid
  docNo           String            @unique @map("doc_no") @db.VarChar(50)
  docDate         DateTime          @map("doc_date") @db.Date
  reason          String?           @db.VarChar(255)
  status          DocumentStatus    @default(DRAFT)
  fiscalStatus    FiscalStatus      @default(DRAFT) @map("fiscal_status")
  fiscalReference String?           @map("fiscal_reference") @db.VarChar(150)
  fiscalizedAt    DateTime?         @map("fiscalized_at") @db.Timestamptz(6)
  fiscalError     String?           @map("fiscal_error") @db.VarChar(255)
  subtotal        Decimal           @db.Decimal(18, 2)
  taxTotal        Decimal           @map("tax_total") @db.Decimal(18, 2)
  grandTotal      Decimal           @map("grand_total") @db.Decimal(18, 2)
  notes           String?
  createdById     String            @map("created_by") @db.Uuid
  postedById      String?           @map("posted_by") @db.Uuid
  series          DocumentSeries    @relation(fields: [seriesId], references: [id])
  salesInvoice    SalesInvoice      @relation(fields: [salesInvoiceId], references: [id])
  customer        Customer          @relation(fields: [customerId], references: [id])
  createdBy       User              @relation("ReturnCreatedBy", fields: [createdById], references: [id])
  postedBy        User?             @relation("ReturnPostedBy", fields: [postedById], references: [id])
  lines           SalesReturnLine[]
  stockMovements  StockMovement[]
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  postedAt        DateTime?         @map("posted_at") @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([seriesId])
  @@index([salesInvoiceId])
  @@index([customerId])
  @@index([createdById])
  @@index([postedById])
  @@index([docDate])
  @@map("sales_returns")
}

model SalesReturnLine {
  id                 String           @id @default(uuid()) @db.Uuid
  salesReturnId      String           @map("sales_return_id") @db.Uuid
  salesInvoiceLineId String           @map("sales_invoice_line_id") @db.Uuid
  itemId             String           @map("item_id") @db.Uuid
  lineNo             Int              @map("line_no")
  qty                Decimal          @db.Decimal(18, 3)
  unitPrice          Decimal          @map("unit_price") @db.Decimal(18, 2)
  taxPercent         Decimal          @map("tax_percent") @db.Decimal(5, 2)
  netAmount          Decimal          @map("net_amount") @db.Decimal(18, 2)
  taxAmount          Decimal          @map("tax_amount") @db.Decimal(18, 2)
  grossAmount        Decimal          @map("gross_amount") @db.Decimal(18, 2)
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  salesReturn        SalesReturn      @relation(fields: [salesReturnId], references: [id], onDelete: Cascade)
  salesInvoiceLine   SalesInvoiceLine @relation(fields: [salesInvoiceLineId], references: [id])
  item               Item             @relation(fields: [itemId], references: [id])

  @@unique([salesReturnId, lineNo])
  @@index([salesInvoiceLineId])
  @@index([itemId])
  @@map("sales_return_lines")
}

model StockMovement {
  id                String           @id @default(uuid()) @db.Uuid
  warehouseId       String           @map("warehouse_id") @db.Uuid
  itemId            String           @map("item_id") @db.Uuid
  movementType      MovementType     @map("movement_type")
  qtyIn             Decimal          @map("qty_in") @db.Decimal(18, 3)
  qtyOut            Decimal          @map("qty_out") @db.Decimal(18, 3)
  unitCost          Decimal?         @map("unit_cost") @db.Decimal(18, 2)
  purchaseInvoiceId String?          @map("purchase_invoice_id") @db.Uuid
  salesInvoiceId    String?          @map("sales_invoice_id") @db.Uuid
  salesReturnId     String?          @map("sales_return_id") @db.Uuid
  referenceNo       String?          @map("reference_no") @db.VarChar(50)
  movementAt        DateTime         @map("movement_at") @db.Timestamptz(6)
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  warehouse         Warehouse        @relation(fields: [warehouseId], references: [id])
  item              Item             @relation(fields: [itemId], references: [id])
  purchaseInvoice   PurchaseInvoice? @relation(fields: [purchaseInvoiceId], references: [id])
  salesInvoice      SalesInvoice?    @relation(fields: [salesInvoiceId], references: [id])
  salesReturn       SalesReturn?     @relation(fields: [salesReturnId], references: [id])

  @@index([warehouseId, itemId])
  @@index([movementType])
  @@index([movementAt])
  @@index([purchaseInvoiceId])
  @@index([salesInvoiceId])
  @@index([salesReturnId])
  @@map("stock_movements")
}

model StockBalance {
  id          String    @id @default(uuid()) @db.Uuid
  warehouseId String    @map("warehouse_id") @db.Uuid
  itemId      String    @map("item_id") @db.Uuid
  qtyOnHand   Decimal   @default(0) @map("qty_on_hand") @db.Decimal(18, 3)
  avgCost     Decimal   @default(0) @map("avg_cost") @db.Decimal(18, 2)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  item        Item      @relation(fields: [itemId], references: [id])

  @@unique([warehouseId, itemId])
  @@index([itemId])
  @@map("stock_balances")
}

model CompanyProfile {
  id                 String     @id @default(uuid()) @db.Uuid
  name               String     @db.VarChar(200)
  fiscalNo           String?    @map("fiscal_no") @db.VarChar(50)
  vatNo              String?    @map("vat_no") @db.VarChar(50)
  businessNo         String?    @map("business_no") @db.VarChar(50)
  address            String?    @db.VarChar(255)
  city               String?    @db.VarChar(100)
  phone              String?    @db.VarChar(50)
  email              String?    @db.VarChar(150)
  website            String?    @db.VarChar(200)
  bankName           String?    @map("bank_name") @db.VarChar(100)
  bankAccount        String?    @map("bank_account") @db.VarChar(50)
  fiscalMode         FiscalMode @default(SANDBOX) @map("fiscal_mode")
  fiscalBusinessUnit String?    @map("fiscal_business_unit") @db.VarChar(50)
  fiscalOperatorCode String?    @map("fiscal_operator_code") @db.VarChar(50)
  fiscalDeviceId     String?    @map("fiscal_device_id") @db.VarChar(100)
  createdAt          DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("company_profile")
}

model FinanceSettlement {
  id                      String                        @id @default(uuid()) @db.Uuid
  entryType               FinanceSettlementType         @map("entry_type")
  status                  FinanceSettlementStatus       @default(OPEN)
  customerId              String?                       @map("customer_id") @db.Uuid
  supplierId              String?                       @map("supplier_id") @db.Uuid
  sourceSalesInvoiceId    String?                       @map("source_sales_invoice_id") @db.Uuid
  sourcePurchaseInvoiceId String?                       @map("source_purchase_invoice_id") @db.Uuid
  sourceAuditLogId        String?                       @map("source_audit_log_id") @db.Uuid
  enteredAmount           Decimal                       @map("entered_amount") @db.Decimal(18, 2)
  sourceAppliedAmount     Decimal                       @map("source_applied_amount") @db.Decimal(18, 2)
  unappliedAmount         Decimal                       @map("unapplied_amount") @db.Decimal(18, 2)
  allocatedAmount         Decimal                       @default(0) @map("allocated_amount") @db.Decimal(18, 2)
  remainingAmount         Decimal                       @map("remaining_amount") @db.Decimal(18, 2)
  paidAt                  DateTime                      @map("paid_at") @db.Date
  referenceNo             String?                       @map("reference_no") @db.VarChar(100)
  notes                   String?
  createdById             String                        @map("created_by") @db.Uuid
  customer                Customer?                     @relation("CustomerFinanceSettlements", fields: [customerId], references: [id])
  supplier                Supplier?                     @relation("SupplierFinanceSettlements", fields: [supplierId], references: [id])
  sourceSalesInvoice      SalesInvoice?                 @relation("FinanceSettlementSourceSalesInvoice", fields: [sourceSalesInvoiceId], references: [id])
  sourcePurchaseInvoice   PurchaseInvoice?              @relation("FinanceSettlementSourcePurchaseInvoice", fields: [sourcePurchaseInvoiceId], references: [id])
  createdBy               User                          @relation("FinanceSettlementCreatedBy", fields: [createdById], references: [id])
  accountTransactions     FinanceAccountTransaction[]
  allocations             FinanceSettlementAllocation[]
  createdAt               DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                      @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([entryType, status])
  @@index([customerId])
  @@index([supplierId])
  @@index([sourceSalesInvoiceId])
  @@index([sourcePurchaseInvoiceId])
  @@index([createdById])
  @@map("finance_settlements")
}

model FinanceSettlementAllocation {
  id                      String            @id @default(uuid()) @db.Uuid
  settlementId            String            @map("settlement_id") @db.Uuid
  targetSalesInvoiceId    String?           @map("target_sales_invoice_id") @db.Uuid
  targetPurchaseInvoiceId String?           @map("target_purchase_invoice_id") @db.Uuid
  amount                  Decimal           @db.Decimal(18, 2)
  allocatedAt             DateTime          @map("allocated_at") @db.Date
  notes                   String?
  amountPaidBefore        Decimal           @map("amount_paid_before") @db.Decimal(18, 2)
  amountPaidAfter         Decimal           @map("amount_paid_after") @db.Decimal(18, 2)
  outstandingBefore       Decimal           @map("outstanding_before") @db.Decimal(18, 2)
  outstandingAfter        Decimal           @map("outstanding_after") @db.Decimal(18, 2)
  paymentStatusBefore     PaymentStatus     @map("payment_status_before")
  paymentStatusAfter      PaymentStatus     @map("payment_status_after")
  createdById             String            @map("created_by") @db.Uuid
  settlement              FinanceSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  targetSalesInvoice      SalesInvoice?     @relation("FinanceSettlementTargetSalesInvoice", fields: [targetSalesInvoiceId], references: [id])
  targetPurchaseInvoice   PurchaseInvoice?  @relation("FinanceSettlementTargetPurchaseInvoice", fields: [targetPurchaseInvoiceId], references: [id])
  createdBy               User              @relation("FinanceSettlementAllocationCreatedBy", fields: [createdById], references: [id])
  createdAt               DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([settlementId])
  @@index([targetSalesInvoiceId])
  @@index([targetPurchaseInvoiceId])
  @@index([createdById])
  @@map("finance_settlement_allocations")
}

model FinanceAccountTransaction {
  id                  String                        @id @default(uuid()) @db.Uuid
  accountId           String                        @map("account_id") @db.Uuid
  financeSettlementId String?                       @map("finance_settlement_id") @db.Uuid
  sourceAuditLogId    String?                       @map("source_audit_log_id") @db.Uuid
  transferGroupId     String?                       @map("transfer_group_id") @db.Uuid
  transactionType     FinanceAccountTransactionType @map("transaction_type")
  amount              Decimal                       @db.Decimal(18, 2)
  balanceBefore       Decimal                       @map("balance_before") @db.Decimal(18, 2)
  balanceAfter        Decimal                       @map("balance_after") @db.Decimal(18, 2)
  transactionDate     DateTime                      @map("transaction_date") @db.Date
  referenceNo         String?                       @map("reference_no") @db.VarChar(100)
  counterpartyName    String?                       @map("counterparty_name") @db.VarChar(200)
  sourceDocumentType  String?                       @map("source_document_type") @db.VarChar(40)
  sourceDocumentId    String?                       @map("source_document_id") @db.Uuid
  sourceDocumentNo    String?                       @map("source_document_no") @db.VarChar(50)
  notes               String?
  createdById         String                        @map("created_by") @db.Uuid
  account             FinanceAccount                @relation(fields: [accountId], references: [id])
  financeSettlement   FinanceSettlement?            @relation(fields: [financeSettlementId], references: [id])
  createdBy           User                          @relation("FinanceAccountTransactionCreatedBy", fields: [createdById], references: [id])
  statementMatches    FinanceStatementMatch[]
  createdAt           DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([accountId, transactionDate])
  @@index([financeSettlementId])
  @@index([sourceAuditLogId])
  @@index([transferGroupId])
  @@index([createdById])
  @@index([sourceDocumentType, sourceDocumentId])
  @@map("finance_account_transactions")
}

model FinanceStatementLine {
  id               String                        @id @default(uuid()) @db.Uuid
  accountId        String                        @map("account_id") @db.Uuid
  direction        FinanceStatementLineDirection
  status           FinanceStatementLineStatus    @default(UNMATCHED)
  statementDate    DateTime                      @map("statement_date") @db.Date
  valueDate        DateTime?                     @map("value_date") @db.Date
  amount           Decimal                       @db.Decimal(18, 2)
  matchedAmount    Decimal                       @default(0) @map("matched_amount") @db.Decimal(18, 2)
  statementBalance Decimal?                      @map("statement_balance") @db.Decimal(18, 2)
  referenceNo      String?                       @map("reference_no") @db.VarChar(100)
  externalId       String?                       @map("external_id") @db.VarChar(100)
  counterpartyName String?                       @map("counterparty_name") @db.VarChar(200)
  description      String?                       @db.VarChar(255)
  notes            String?
  createdById      String                        @map("created_by") @db.Uuid
  account          FinanceAccount                @relation(fields: [accountId], references: [id])
  createdBy        User                          @relation("FinanceStatementLineCreatedBy", fields: [createdById], references: [id])
  matches          FinanceStatementMatch[]
  createdAt        DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                      @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([accountId, statementDate])
  @@index([status])
  @@index([direction])
  @@index([externalId])
  @@map("finance_statement_lines")
}

model FinanceStatementMatch {
  id                          String                    @id @default(uuid()) @db.Uuid
  statementLineId             String                    @map("statement_line_id") @db.Uuid
  financeAccountTransactionId String                    @map("finance_account_transaction_id") @db.Uuid
  amount                      Decimal                   @db.Decimal(18, 2)
  notes                       String?
  createdById                 String                    @map("created_by") @db.Uuid
  statementLine               FinanceStatementLine      @relation(fields: [statementLineId], references: [id], onDelete: Cascade)
  financeAccountTransaction   FinanceAccountTransaction @relation(fields: [financeAccountTransactionId], references: [id])
  createdBy                   User                      @relation("FinanceStatementMatchCreatedBy", fields: [createdById], references: [id])
  createdAt                   DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([statementLineId, financeAccountTransactionId])
  @@index([statementLineId])
  @@index([financeAccountTransactionId])
  @@index([createdById])
  @@map("finance_statement_matches")
}

model FinancialPeriod {
  id             String                @id @default(uuid()) @db.Uuid
  year           Int
  month          Int
  periodStart    DateTime              @map("period_start") @db.Date
  periodEnd      DateTime              @map("period_end") @db.Date
  status         FinancialPeriodStatus @default(OPEN)
  closedAt       DateTime?             @map("closed_at") @db.Timestamptz(6)
  closedById     String?               @map("closed_by") @db.Uuid
  closedReason   String?               @map("closed_reason") @db.VarChar(255)
  reopenedAt     DateTime?             @map("reopened_at") @db.Timestamptz(6)
  reopenedById   String?               @map("reopened_by") @db.Uuid
  reopenedReason String?               @map("reopened_reason") @db.VarChar(255)
  closedBy       User?                 @relation("FinancialPeriodClosedBy", fields: [closedById], references: [id])
  reopenedBy     User?                 @relation("FinancialPeriodReopenedBy", fields: [reopenedById], references: [id])
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([year, month])
  @@index([status])
  @@index([periodStart, periodEnd])
  @@index([closedById])
  @@index([reopenedById])
  @@map("financial_periods")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String   @map("entity_id") @db.Uuid
  action     String   @db.VarChar(50)
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
